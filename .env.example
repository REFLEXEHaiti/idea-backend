# ═══════════════════════════════════════════
# Plateforme Débat Haïti — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════

# Base de données PostgreSQL (Railway fourni automatiquement)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# JWT
JWT_SECRET=change_this_to_a_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Email Gmail (déjà configuré dans le code)
SMTP_USER=debathaiti87@gmail.com
SMTP_PASS=dhzcjghwcjsouaf

# URL du frontend
FRONTEND_URL=https://plateforme-debat-frontend.vercel.app

# Stripe (paiements carte)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MonCash (Digicel Haïti)
MONCASH_API_URL=https://moncashbutton.digicelgroup.com/Api
MONCASH_CLIENT_ID=
MONCASH_SECRET_KEY=

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic (IA)
ANTHROPIC_API_KEY=sk-ant-...

# Port (Railway le définit automatiquement)
PORT=3001
