# ══════════════════════════════════════════
# DEBAT HAITI — BACKEND — Variables d'env
# Copiez en .env et remplissez les valeurs
# ══════════════════════════════════════════

# Base de données PostgreSQL (Supabase, Railway, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public

# JWT secret (min. 32 caractères, aléatoire)
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire

# Durée de validité du token (ex: 7d, 24h)
JWT_EXPIRES_IN=7d

# URL du frontend (pour les redirections email)
FRONTEND_URL=https://plateforme-debat-frontend.vercel.app

# SMTP Gmail (pour les emails de réinitialisation)
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_app_password_gmail

# Stripe (paiements carte)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MonCash (paiements Haïti)
MONCASH_CLIENT_ID=votre_client_id
MONCASH_CLIENT_SECRET=votre_client_secret
MONCASH_MODE=production  # ou sandbox

# Anthropic (IA feedbacks)
ANTHROPIC_API_KEY=sk-ant-...

# Port du serveur
PORT=3001
