# ═══════════════════════════════════════════════════
# Plateforme Débat Haïti — Variables d'environnement
# Copier ce fichier en .env et remplir TOUTES les valeurs
# NE JAMAIS committer le fichier .env sur GitHub
# ═══════════════════════════════════════════════════

# Base de données PostgreSQL (Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# JWT
JWT_SECRET=changez_cette_valeur_avec_au_moins_32_caracteres_aleatoires
JWT_EXPIRES_IN=7d

# Email (Gmail avec mot de passe d'application — PAS votre vrai mot de passe)
# Créer un mot de passe d'application : https://myaccount.google.com/apppasswords
SMTP_USER=votre-email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# URL du frontend
FRONTEND_URL=https://plateforme-debat-frontend.vercel.app

# Stripe (paiements carte)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MonCash (Digicel Haïti)
MONCASH_API_URL=https://moncashbutton.digicelgroup.com/Api
MONCASH_CLIENT_ID=
MONCASH_SECRET_KEY=

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic (IA)
ANTHROPIC_API_KEY=sk-ant-...

# Port (Railway le définit automatiquement)
PORT=3001
