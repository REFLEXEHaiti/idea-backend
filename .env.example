# ─────────────────────────────────────────────
# IDEA Haiti — Backend Multi-Tenant
# Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL (Railway ou Supabase)
DATABASE_URL="postgresql://user:password@host:5432/idea_haiti_db?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/idea_haiti_db?schema=public"

# JWT — Générez un secret fort avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="votre_secret_jwt_tres_long_et_aleatoire"
JWT_EXPIRES_IN="24h"

# Frontends (séparés par virgule si plusieurs)
# En dev : FRONTEND_URL=http://localhost:3000
# En prod : FRONTEND_URL=https://lexhaiti.com,https://techprohaiti.com,https://mediformhaiti.com
FRONTEND_URL="http://localhost:3000"

# ─── Anthropic (Claude AI) ────────────────────
# Obtenez votre clé sur : console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── Stripe (paiements cartes internationales) ─
# Obtenez vos clés sur : dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── MonCash (paiements mobile Haïti) ──────────
# Obtenez vos credentials sur le portail MonCash Digicel
MONCASH_API_URL="https://sandbox.moncashbutton.digicelgroup.com/Api"
MONCASH_CLIENT_ID="votre_client_id_moncash"
MONCASH_SECRET_KEY="votre_secret_moncash"

# ─── Email SMTP (réinitialisation mot de passe) ─
# Utiliser un compte Gmail avec mot de passe d'application
SMTP_USER="votre_email@gmail.com"
SMTP_PASS="votre_mot_de_passe_application_gmail"

# ─────────────────────────────────────────────
# UTILISATION :
#
# Chaque requête doit envoyer le header :
#   X-Tenant-ID: lex        (pour LexHaiti)
#   X-Tenant-ID: techpro    (pour TechPro Haiti)
#   X-Tenant-ID: mediform   (pour MediForm Haiti)
#
# En développement, vous pouvez aussi utiliser :
#   ?tenant=lex dans l'URL
# ─────────────────────────────────────────────
